                "cinematicBody": "\u0627\u0633\u062a\u062e\u062f\u0645 Zoom \u0628\u0634\u0643\u0644 \u0645\u062d\u062f\u0648\u062f \u0645\u0639 \u0627\u0644\u0635\u0648\u0631 \u0627\u0644\u0631\u0626\u064a\u0633\u064a\u0629 \u0648\u0623\u0628\u0642 \u0627\u0644\u062d\u0644\u0642\u0627\u062a \u0627\u0644\u0637\u0648\u064a\u0644\u0629 \u0642\u0635\u064a\u0631\u0629 \u062d\u062a\u0649 \u0644\u0627 \u062a\u0634\u0639\u0631 \u0627\u0644\u062d\u0631\u0643\u0629 \u0628\u0627\u0644\u062b\u0642\u0644.",
                "safeModeTitle": "\u0644\u0644\u0623\u062c\u0647\u0632\u0629 \u0627\u0644\u0623\u0636\u0639\u0641",
                "safeModeBody": "\u0627\u062e\u062a\u0631 None \u0623\u0648 Fade \u0623\u0648 Random Safe \u0639\u0646\u062f\u0645\u0627 \u064a\u0643\u0648\u0646 \u0627\u0644\u062c\u0647\u0627\u0632 \u0623\u0642\u062f\u0645 \u0623\u0648 \u0639\u0646\u062f \u062f\u0645\u062c \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0645\u0639 \u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0648\u064a\u0628.",
                "durationTitle": "\u0646\u0635\u0627\u0626\u062d \u0627\u0644\u0645\u062f\u0629",
                "durationIntro": "\u062a\u0624\u062b\u0631 \u0645\u062f\u0629 \u0627\u0644\u0627\u0646\u062a\u0642\u0627\u0644 \u0639\u0644\u0649 \u0627\u0644\u0633\u0631\u0639\u0629 \u0627\u0644\u0645\u062d\u0633\u0648\u0633\u0629 \u0623\u0643\u062b\u0631 \u0645\u0646 \u0646\u0648\u0639 \u0627\u0644\u062d\u0631\u0643\u0629. \u062d\u0627\u0641\u0638 \u0639\u0644\u064a\u0647\u0627 \u0642\u0635\u064a\u0631\u0629 \u0628\u0645\u0627 \u064a\u062d\u0645\u064a \u0648\u0636\u0648\u062d \u0627\u0644\u0646\u0635.",
                "fastTitle": "\u0633\u0631\u064a\u0639 (100-300 ms)",
                "fastBody": "\u0627\u0644\u0623\u0641\u0636\u0644 \u0644\u0644\u062f\u0648\u0631\u0627\u062a \u0627\u0644\u0633\u0631\u064a\u0639\u0629 \u0648\u0644\u0648\u062d\u0627\u062a \u0627\u0644\u0623\u0633\u0639\u0627\u0631 \u0648\u0627\u0644\u0648\u064a\u062f\u062c\u062a\u0633 \u0627\u0644\u0635\u063a\u064a\u0631\u0629.",
                "recommendedTitle": "\u0645\u0648\u0635\u0649 \u0628\u0647 (300-500 ms)",
                "recommendedBody": "\u0623\u0643\u062b\u0631 \u0645\u062f\u0649 \u0645\u062a\u0648\u0627\u0632\u0646 \u0644\u0642\u0648\u0627\u0626\u0645 \u0627\u0644\u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u064a\u0648\u0645\u064a\u0629. \u064a\u0628\u062f\u0648 \u0633\u0644\u0633\u064b\u0627 \u062f\u0648\u0646 \u0625\u0628\u0637\u0627\u0621 \u0627\u0644\u062d\u0644\u0642\u0629.",
                "longTitle": "\u0637\u0648\u064a\u0644 (600-900 ms)",
                "longBody": "\u0627\u0633\u062a\u062e\u062f\u0645\u0647 \u0641\u0642\u0637 \u0645\u0639 \u0627\u0644\u062d\u0645\u0644\u0627\u062a \u0645\u0644\u0621 \u0627\u0644\u0634\u0627\u0634\u0629 \u0623\u0648 \u0627\u0644\u0645\u0631\u0626\u064a\u0627\u062a \u0627\u0644\u0645\u0645\u064a\u0632\u0629. \u0642\u062f \u062a\u062c\u0639\u0644 \u0627\u0644\u0642\u064a\u0645 \u0627\u0644\u0637\u0648\u064a\u0644\u0629 \u0642\u0627\u0626\u0645\u0627\u062a \u0627\u0644\u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u0645\u0632\u062f\u062d\u0645\u0629 \u0628\u0637\u064a\u0626\u0629."
