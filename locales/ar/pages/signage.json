                "bestPracticeBody": "\u064a\u0639\u062f Fade \u0623\u0648 Crossfade \u0627\u0644\u062e\u064a\u0627\u0631 \u0627\u0644\u0623\u0643\u062b\u0631 \u0623\u0645\u0627\u0646\u064b\u0627 \u0644\u0642\u0648\u0627\u0626\u0645 \u0627\u0644\u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u0645\u062e\u062a\u0644\u0637\u0629 \u0648\u0627\u0644\u0634\u0627\u0634\u0627\u062a \u062f\u0627\u0626\u0645\u0629 \u0627\u0644\u062a\u0634\u063a\u064a\u0644.",
                "productFlowTitle": "\u0644\u0642\u0648\u0627\u0626\u0645 \u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a",
                "productFlowBody": "\u064a\u0646\u0627\u0633\u0628 Push \u0648 Wipe \u0627\u0644\u0623\u0633\u0639\u0627\u0631 \u0648\u0627\u0644\u0642\u0648\u0627\u0626\u0645 \u0648\u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0645\u0631\u062a\u0628 \u0644\u0623\u0646\u0647\u0645\u0627 \u064a\u062d\u0627\u0641\u0638\u0627\u0646 \u0639\u0644\u0649 \u0627\u062a\u062c\u0627\u0647 \u0627\u0644\u0642\u0631\u0627\u0621\u0629.",
