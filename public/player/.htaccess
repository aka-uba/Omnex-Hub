# Omnex Player - Apache Configuration
# Enable PWA features and proper caching

# Enable rewrite engine
RewriteEngine On

# Force HTTPS in production
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Ensure proper MIME types for JavaScript modules
<IfModule mod_mime.c>
    AddDefaultCharset UTF-8
    AddCharset UTF-8 .html .css .js .mjs .json .webmanifest
    AddType application/javascript .js
    AddType text/javascript .mjs
</IfModule>

# Don't redirect static assets
RewriteCond %{REQUEST_URI} \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|json|webmanifest)$ [NC]
RewriteRule ^ - [L]

# Handle SPA routing - return index.html for all routes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.html [L,QSA]

# CORS Headers for PWA
<IfModule mod_headers.c>
    # Allow service worker scope
    Header set Service-Worker-Allowed "/"

    # CORS for API calls (restrict to same-origin; cross-origin handled by API layer)
    Header set Access-Control-Allow-Methods "GET, POST, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type, X-DEVICE-TOKEN, Authorization"
</IfModule>

# Cache Control
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML - no cache
    ExpiresByType text/html "access plus 0 seconds"

    # CSS/JS - 1 hour (versioned)
    ExpiresByType text/css "access plus 1 hour"
    ExpiresByType application/javascript "access plus 1 hour"

    # Images - 1 year
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"

    # Fonts - 1 year
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"

    # Manifest and SW - no cache
    ExpiresByType application/manifest+json "access plus 0 seconds"
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/manifest+json
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Disable directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
