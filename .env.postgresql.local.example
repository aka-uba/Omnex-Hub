# PostgreSQL profile: local
OMNEX_DB_DRIVER=pgsql
OMNEX_DB_PROFILE=local

OMNEX_DB_HOST=127.0.0.1
OMNEX_DB_PORT=5432
OMNEX_DB_NAME=market_etiket
OMNEX_DB_USER=postgres
OMNEX_DB_PASS=postgres

OMNEX_DB_SSLMODE=disable
OMNEX_DB_CONNECT_TIMEOUT=5
OMNEX_DB_APP_NAME=market-etiket-sistemi-local
OMNEX_DB_SEARCH_PATH=core,license,catalog,branch,labels,media,devices,signage,integration,audit,legacy,public

# Optional: set explicit FFmpeg binaries (recommended on Windows local)
# FFMPEG_PATH=C:\Users\<USER>\AppData\Local\Microsoft\WinGet\Links\ffmpeg.exe
# FFPROBE_PATH=C:\Users\<USER>\AppData\Local\Microsoft\WinGet\Links\ffprobe.exe

# Optional: professional live channel pipeline (single continuous timeline)
# STREAM_CHANNEL_MODE=true
# STREAM_CHANNEL_SYNC_BOOTSTRAP=1
# STREAM_CHANNEL_PLAYLIST_SIZE=12
# STREAM_CHANNEL_IDLE_TIMEOUT=300

# Optional single-string alternative:
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/market_etiket?sslmode=disable&application_name=market-etiket-sistemi-local
