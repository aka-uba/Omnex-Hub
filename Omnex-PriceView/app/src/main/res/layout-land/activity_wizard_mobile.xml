<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wizard_mobile_background"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/wizardBrand"
        android:layout_width="160dp"
        android:layout_height="42dp"
        android:layout_marginTop="8dp"
        android:adjustViewBounds="true"
        android:animation="@anim/logo_breath"
        android:contentDescription="@string/app_name"
        android:scaleType="fitCenter"
        android:src="@drawable/brand_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/keyboardDimOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0"
        android:background="#7A020810"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/wizardActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="10dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/btn_secondary"
            android:fontFamily="sans-serif-medium"
            android:text="@string/wizard_back"
            android:textAllCaps="false"
            android:textColor="#8A9DB8"
            android:textSize="14sp"
            android:visibility="invisible" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/btn_primary"
            android:fontFamily="sans-serif-medium"
            android:text="@string/wizard_next"
            android:textAllCaps="false"
            android:textColor="#F0F6FF"
            android:textSize="14sp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/wizardScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls"
        android:paddingStart="14dp"
        android:paddingTop="6dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp"
        app:layout_constraintBottom_toTopOf="@id/wizardActions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/wizardBrand">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:weightSum="1">

            <!-- Left: Icon + step indicators -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:layout_weight="0.42"
                android:background="@drawable/wizard_mobile_card_bg"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp">

                <ImageView
                    android:id="@+id/wizardImage"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="@null"
                    android:src="@drawable/wizard_welcome" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/step1"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/step_indicator_mobile" />

                    <View
                        android:id="@+id/step2"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/step_indicator_mobile" />

                    <View
                        android:id="@+id/step3"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@drawable/step_indicator_mobile" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right: Content card -->
            <LinearLayout
                android:id="@+id/wizardContentCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.58"
                android:background="@drawable/wizard_mobile_card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/wizardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.01"
                    android:textColor="#F0F6FF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/wizardDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="sans-serif"
                    android:lineSpacingMultiplier="1.2"
                    android:textColor="#8A9DB8"
                    android:textSize="13sp" />

                <LinearLayout
                    android:id="@+id/serverUrlLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/wizard_server_title"
                        android:textColor="#B0C4DE"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/serverUrlInput"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:background="@drawable/input_background"
                        android:fontFamily="sans-serif"
                        android:hint="@string/wizard_server_hint"
                        android:imeOptions="actionDone"
                        android:inputType="textUri"
                        android:maxLines="1"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="#E0EAFF"
                        android:textColorHint="#4A6080"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnUseDefaultServer"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/btn_secondary"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/wizard_use_default_server"
                        android:textAllCaps="false"
                        android:textColor="#8ABCC8"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif"
                        android:text="@string/wizard_server_example"
                        android:textColor="#4A6080"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
