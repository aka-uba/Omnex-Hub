<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wizard_mobile_background"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/wizard_card_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="28dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <ImageView
            android:layout_width="210dp"
            android:layout_height="58dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/brand_logo" />

        <TextView
            android:id="@+id/errorTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="Omnex Player"
            android:textColor="#F8FBFF"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/errorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:text="Player baslatilamadi."
            android:textColor="#CDDAEE"
            android:textSize="18sp" />

        <Button
            android:id="@+id/retryButton"
            android:layout_width="260dp"
            android:layout_height="58dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/btn_primary"
            android:fontFamily="sans-serif-medium"
            android:text="Tekrar Dene"
            android:textAllCaps="false"
            android:textColor="#F8FBFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/wizardButton"
            android:layout_width="260dp"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/btn_secondary"
            android:fontFamily="sans-serif-medium"
            android:text="Kurulum Sihirbazi"
            android:textAllCaps="false"
            android:textColor="#EAF2FF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
