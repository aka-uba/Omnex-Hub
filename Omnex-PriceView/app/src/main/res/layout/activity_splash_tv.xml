<?xml version="1.0" encoding="utf-8"?>
<!-- TV Splash Screen - Lottie animation + title + version -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wizard_mobile_background">

    <!-- Splash Video (hidden until splash_video resource exists) -->
    <VideoView
        android:id="@+id/splashVideoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Logo container -->
    <LinearLayout
        android:id="@+id/splashLogoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Lottie Animasyonlu Logo -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/splashLottie"
            android:layout_width="320dp"
            android:layout_height="320dp"
            app:lottie_rawRes="@raw/price_splash_animation"
            app:lottie_autoPlay="false"
            app:lottie_loop="false" />

        <!-- OmneX Fiyat Gör Başlığı -->
        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="OmneX Fiyat Gör"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:visibility="invisible" />

        <!-- Sürüm notu -->
        <TextView
            android:id="@+id/splashVersionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/splash_version_placeholder"
            android:textColor="#9FB2D2"
            android:textSize="16sp"
            android:visibility="invisible" />

    </LinearLayout>

</FrameLayout>
