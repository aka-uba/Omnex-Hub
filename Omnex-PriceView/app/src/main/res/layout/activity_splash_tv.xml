<?xml version="1.0" encoding="utf-8"?>
<!-- TV Splash Screen - Brand logo (PNG) + loading indicator -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wizard_mobile_background">

    <!-- Splash Video (hidden until splash_video resource exists) -->
    <VideoView
        android:id="@+id/splashVideoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Logo container -->
    <LinearLayout
        android:id="@+id/splashLogoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="40dp"
        android:paddingTop="32dp"
        android:paddingEnd="40dp"
        android:paddingBottom="32dp">

        <!-- Brand logo PNG (icon + text as designed) -->
        <ImageView
            android:id="@+id/splashLogoIcon"
            android:layout_width="360dp"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:alpha="0"
            android:scaleType="fitCenter"
            android:src="@drawable/brand_logo" />

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/splashProgress"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="40dp"
            android:alpha="0"
            android:indeterminateTint="#63B7FF" />

    </LinearLayout>

</FrameLayout>
