<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Layer 0: ExoPlayer (existing signage video) -->
    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:use_controller="false"
        app:surface_type="texture_view"
        app:resize_mode="fit" />

    <!-- Layer 1: Signage WebView (existing) -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Layer 2: PriceView Overlay (shown when product found/not found) -->
    <FrameLayout
        android:id="@+id/priceViewOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="50dp"
        android:translationZ="50dp"
        android:visibility="gone">

        <!-- HTML product overlay (mode=html) -->
        <WebView
            android:id="@+id/productHtmlOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:visibility="gone" />

        <!-- HTML not-found overlay (mode=html) -->
        <WebView
            android:id="@+id/notFoundHtmlOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:visibility="gone" />

        <!-- Product not found message -->
        <include layout="@layout/overlay_not_found" />

        <!-- Product info card (bottom, slides up) -->
        <include layout="@layout/overlay_product_info" />

    </FrameLayout>

    <!-- Layer 3: Camera fullscreen (opens on FAB tap, closes on scan) -->
    <FrameLayout
        android:id="@+id/cameraPipContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:elevation="60dp"
        android:translationZ="60dp"
        android:visibility="gone">

        <androidx.camera.view.PreviewView
            android:id="@+id/cameraPipPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Scan indicator dot (green pulsing) -->
        <View
            android:id="@+id/scanIndicatorDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:background="@drawable/scan_indicator_dot" />

        <!-- Top bar: instruction text + close button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#88000000"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Barkodu kameraya g&#246;sterin"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnPickFromGallery"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/player_control_circle"
                android:src="@android:drawable/ic_menu_gallery"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:contentDescription="Galeriden Se&#231;" />

            <ImageButton
                android:id="@+id/btnCloseCamera"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/player_control_circle"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:contentDescription="Kapat" />
        </LinearLayout>

        <!-- Center crosshair guide -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:background="@android:color/transparent" />
    </FrameLayout>

    <!-- Layer 4: FAB scan button (always above WebView content) -->
    <ImageButton
        android:id="@+id/fabScanButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/player_control_circle"
        android:src="@android:drawable/ic_menu_camera"
        android:scaleType="centerInside"
        android:padding="10dp"
        android:contentDescription="Barkod Tara"
        android:elevation="60dp"
        android:translationZ="60dp"
        android:visibility="gone" />

    <!-- Layer 5: Sync progress indicator (top-center) -->
    <LinearLayout
        android:id="@+id/syncProgressContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC1a1a2e"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:elevation="60dp"
        android:translationZ="60dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/syncProgressSpinner"
            style="@android:style/Widget.ProgressBar.Small"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:indeterminateTint="#6366f1" />

        <TextView
            android:id="@+id/syncProgressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Layer 6: ProgressBar (existing) -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_gravity="top"
        android:max="100"
        android:progressTint="#6366f1"
        android:progressBackgroundTint="#1a1a2e"
        android:elevation="60dp"
        android:translationZ="60dp"
        android:visibility="gone" />

</FrameLayout>
