# ========================================
# Omnex Display Hub - Shared Proxy Configuration
# Copy to .env and configure all values
# ========================================

# ---- Let's Encrypt ----
# Email for certificate expiry notifications
ACME_EMAIL=admin@example.com

# ---- Proxy Domain ----
# Base domain for the proxy server
# Traefik dashboard will be at: traefik.PROXY_DOMAIN
PROXY_DOMAIN=example.com

# ---- Dashboard Auth ----
# Basic auth for Traefik dashboard
# Generate with: htpasswd -nB admin
# Format: user:hashed_password (escape $ with $$ in docker-compose)
# Example: admin:$$2y$$05$$xxx...
DASHBOARD_AUTH=admin:$$2y$$05$$CHANGE_ME_GENERATE_WITH_HTPASSWD

# ---- Logging ----
TRAEFIK_LOG_LEVEL=WARN
TRAEFIK_ACCESS_LOG=false
