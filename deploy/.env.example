# ========================================
# Omnex Display Hub - Production Environment
# Copy to .env and configure all values
# ========================================

# ---- Database ----
OMNEX_DB_DRIVER=pgsql
OMNEX_DB_HOST=postgres
OMNEX_DB_PORT=5432
OMNEX_DB_NAME=omnex_hub
OMNEX_DB_USER=omnex
OMNEX_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---- Security ----
OMNEX_JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
OMNEX_FORCE_HTTPS=true
OMNEX_SKIP_CSRF=false

# ---- Production Mode ----
OMNEX_PRODUCTION=true

# ---- Admin Account (first run only) ----
OMNEX_ADMIN_EMAIL=admin@omnex.local
OMNEX_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ---- Domain & SSL ----
OMNEX_DOMAIN=example.com

# ---- SMTP (optional) ----
# OMNEX_SMTP_HOST=smtp.gmail.com
# OMNEX_SMTP_PORT=587
# OMNEX_SMTP_USER=
# OMNEX_SMTP_PASSWORD=
# OMNEX_SMTP_FROM=noreply@example.com
