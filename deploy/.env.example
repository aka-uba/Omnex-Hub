# ========================================
# Omnex Display Hub - Production Environment
# Copy to .env and configure all values
# ========================================

# ---- Project Identity ----
# Unique name for this stack (REQUIRED for multi-project)
# Used as Docker Compose project name and Traefik router prefix
# Examples: omnex-panel, customer-acme, customer-globex
COMPOSE_PROJECT_NAME=omnex

# ---- Deploy Mode ----
# standalone = built-in nginx + certbot (single server)
# multi     = behind shared Traefik proxy (multi-project)
DEPLOY_MODE=standalone

# ---- Domain & SSL ----
# Required for both standalone (certbot) and multi (Traefik routing)
OMNEX_DOMAIN=example.com

# ---- Database ----
OMNEX_DB_DRIVER=pgsql
OMNEX_DB_HOST=postgres
OMNEX_DB_PORT=5432
OMNEX_DB_NAME=omnex_hub
OMNEX_DB_USER=omnex
OMNEX_DB_PASS=CHANGE_ME_STRONG_PASSWORD

# ---- Security ----
OMNEX_JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
OMNEX_FORCE_HTTPS=true
OMNEX_SKIP_CSRF=false

# ---- Production Mode ----
OMNEX_PRODUCTION=true

# ---- Admin Account (first run only) ----
OMNEX_ADMIN_EMAIL=admin@omnex.local
OMNEX_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ---- Ports ----
# App admin port (localhost only, for health checks and direct access)
# MUST be unique per stack in multi-project mode
APP_PORT=8080

# Nginx ports (standalone mode only)
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443

# ---- SMTP (optional) ----
# OMNEX_SMTP_HOST=smtp.gmail.com
# OMNEX_SMTP_PORT=587
# OMNEX_SMTP_USER=
# OMNEX_SMTP_PASSWORD=
# OMNEX_SMTP_FROM=noreply@example.com
