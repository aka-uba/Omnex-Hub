# PostgreSQL profile: docker (app + postgres in same compose network)
OMNEX_DB_DRIVER=pgsql
OMNEX_DB_PROFILE=docker

# Service name of postgres container
OMNEX_DB_HOST=postgres
OMNEX_DB_PORT=5432
OMNEX_DB_NAME=market_etiket
OMNEX_DB_USER=market_user
OMNEX_DB_PASS=market_pass

OMNEX_DB_SSLMODE=disable
OMNEX_DB_CONNECT_TIMEOUT=5
OMNEX_DB_APP_NAME=market-etiket-sistemi-docker
OMNEX_DB_SEARCH_PATH=core,license,catalog,branch,labels,media,devices,signage,integration,audit,legacy,public

# Optional single-string alternative:
# DATABASE_URL=postgresql://market_user:market_pass@postgres:5432/market_etiket?sslmode=disable&application_name=market-etiket-sistemi-docker
