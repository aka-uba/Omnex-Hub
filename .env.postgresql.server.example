# PostgreSQL profile: server / production
OMNEX_DB_DRIVER=pgsql
OMNEX_DB_PROFILE=server

OMNEX_DB_HOST=127.0.0.1
OMNEX_DB_PORT=5432
OMNEX_DB_NAME=market_etiket
OMNEX_DB_USER=market_app
OMNEX_DB_PASS=change_this_password

# Use require/verify-full based on server TLS policy
OMNEX_DB_SSLMODE=require
OMNEX_DB_CONNECT_TIMEOUT=10
OMNEX_DB_APP_NAME=market-etiket-sistemi-prod
OMNEX_DB_SEARCH_PATH=core,license,catalog,branch,labels,media,devices,signage,integration,audit,legacy,public

# Optional but recommended: set explicit FFmpeg binaries in server/container
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# Optional: professional live channel pipeline (recommended for 24/7 stream)
# STREAM_CHANNEL_MODE=true
# STREAM_CHANNEL_SYNC_BOOTSTRAP=0
# STREAM_CHANNEL_PLAYLIST_SIZE=12
# STREAM_CHANNEL_IDLE_TIMEOUT=300

# Optional single-string alternative:
# DATABASE_URL=postgresql://market_app:change_this_password@127.0.0.1:5432/market_etiket?sslmode=require&application_name=market-etiket-sistemi-prod
